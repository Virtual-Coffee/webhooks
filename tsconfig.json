{
  "compilerOptions": {
    "target": "ES2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "functions/**/*.ts",
    "util/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
